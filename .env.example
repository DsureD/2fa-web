# 访问密码 - 用于前端登录验证
ACCESS_PASSWORD=change_me_to_a_strong_password

# 敏感操作密码 - 查看密钥/删除账户时二次验证（留空则不启用）
SENSITIVE_PASSWORD=change_me_to_another_password

# hCaptcha 人机验证 - 登录时防暴力破解（留空则不启用）
# 前往 https://dashboard.hcaptcha.com 注册获取
HCAPTCHA_SITE_KEY=
HCAPTCHA_SECRET_KEY=

# Flask Session 密钥
SECRET_KEY=change_me_to_a_random_string_abc123

# 服务器配置
HOST=0.0.0.0
PORT=5000
